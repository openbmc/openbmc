     } else if (active_index == BANK_1) {
         previous_active_index = BANK_0;
-        bank_offset = BANK_0_PARTITION_OFFSET;
     } else {
         FWU_LOG_MSG("ERROR: %s: active_index %d\n\r",__func__,active_index);
         ret = PSA_ERROR_DATA_INVALID;
