-                               0,
-                               unicode_name,
-                               &new_guid);
-        if (ret == PSA_ERROR_INSUFFICIENT_STORAGE) {
-            FWU_LOG_MSG("%s: No space left on device!\r\n", __func__);
-            return ret;
