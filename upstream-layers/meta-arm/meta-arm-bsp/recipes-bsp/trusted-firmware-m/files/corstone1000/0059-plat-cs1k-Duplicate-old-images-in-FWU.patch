-    size_t data_size;
-    size_t offset_read = active_part.start * TFM_GPT_BLOCK_SIZE;
-    size_t offset_write = prev_active_part.start * TFM_GPT_BLOCK_SIZE;
-    int data_transferred_count;
-#endif /* BL1_BUILD */
 
