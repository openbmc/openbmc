-        char unicode_name[GPT_ENTRY_NAME_LENGTH] = {'\0'};
-        ascii_to_unicode(fwu_image[image_index].image_names[previous_active_index], unicode_name);
-
-        ret = gpt_entry_create(&(fwu_image[image_index].image_type),
