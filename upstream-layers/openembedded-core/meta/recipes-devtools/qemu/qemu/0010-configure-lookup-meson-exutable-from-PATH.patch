From ef9ea8e83468ce974079964a5104df170beba85b Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Martin=20Hundeb=C3=B8ll?= <martin@geanix.com>
Date: Wed, 22 May 2024 14:02:55 +0200
Subject: [PATCH] configure: lookup meson exutable from PATH

Upstream-Status: Inappropriate [workaround, would need a real fix for upstream]

Update context for qemu 10.2.0.

Signed-off-by: Kai Kang <kai.kang@windriver.com>
---
 configure | 5 +----
 1 file changed, 1 insertion(+), 4 deletions(-)

diff --git a/configure b/configure
index eea903067..217af781f 100755
--- a/configure
+++ b/configure
@@ -981,10 +981,7 @@ get_pwd() {
     fi
 }
 
-meson="$(cd pyvenv/bin; get_pwd)/meson"
-if [ -f "$meson$EXESUF" ]; then
-  meson="$meson$EXESUF"
-fi
+meson=`which meson`
 
 # On Haiku, meson might show up in a "non-packaged" subfolder instead, see
 # https://github.com/haiku/haiku/blob/r1beta5/docs/user/storage/storageintro.dox
