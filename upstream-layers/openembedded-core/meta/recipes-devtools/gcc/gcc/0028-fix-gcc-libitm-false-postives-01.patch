@@ -33,48 +32,42 @@ set blddir [lookfor_file [get_multilibs] libitm]
 
 
 if { $blddir != "" } {
-    # Look for a static libstdc++ first.
-    if [file exists "${blddir}/${lang_library_path}/libstdc++.a"] {
-	set lang_test_file "${lang_library_path}/libstdc++.a"
