#!/bin/bash

help_msg="
Usage: vr-fault-event-logger <event> <gpio_name>
<event> is the power rail event to log,
e.g. assert / deassert.

<gpio_name> is defined in json file,
e.g. FM_P12V_NIC1_FLTB_R_N
"

gpio_name="$2"
msg_id="xyz.openbmc_project.State.Power.VoltageRegulatorFault"
# Board name differs per machine; read OPENBMC_TARGET_MACHINE from os-release
# so this shared script produces the correct inventory path on each platform.
# shellcheck source=/dev/null
. /etc/os-release 2>/dev/null
case "$OPENBMC_TARGET_MACHINE" in
    clemente) _pdb="Clemente_PDB" ;;
    *) _pdb="Catalina_PDB" ;;
esac
device_path="/xyz/openbmc_project/inventory/system/board/$_pdb/$gpio_name"
# log-create writes the new entry's object path to stash_file; deassert reads
# it back to resolve the same entry via log-resolve.
stash_file="/run/${gpio_name}.log_entry"

get_failure_data()
{
    if [ "$1" = "FM_P12V_NIC1_FLTB_R_N" ]; then
        echo "NIC1 P12V_AUX Efuse fault assert"
    elif [ "$1" = "FM_P3V3_NIC1_FAULT_R_N" ]; then
        echo "NIC1 P3V3_AUX Efuse fault assert"
    elif [ "$1" = "FM_P12V_NIC0_FLTB_R_N" ]; then
        echo "NIC0 P12V_AUX Efuse fault assert"
    elif [ "$1" = "FM_P3V3_NIC0_FAULT_R_N" ]; then
        echo "NIC0 P3V3_AUX Efuse fault assert"
    elif [ "$1" = "P12V_AUX_FAN_OC_PLD_N" ]; then
        echo "P12V_AUX_FAN VR OC fault assert"
    elif [ "$1" = "P12V_AUX_FAN_FAULT_PLD_N" ]; then
        echo "P12V_AUX_FAN VR fault assert"
    elif [ "$1" = "NODEB_PSU_SMB_ALERT_R_L" ]; then
        echo "CPU1 P12V_N2_VOUT VR alert assert"
    elif [ "$1" = "NODEA_PSU_SMB_ALERT_R_L" ]; then
        echo "CPU0 P12V_N1_VOUT VR alert assert"
    elif [ "$1" = "P12V_AUX_PSU_SMB_ALERT_R_L" ]; then
        echo "P12V_AUX VR alert assert"
    elif [ "$1" = "P12V_AUX_FAN_ALERT_PLD_N" ]; then
        echo "FAN P12V_AUX_FAN VR alert assert"
    else
        echo "GPIO $1 assert"
    fi
}

case "$1" in
    "-h")
        echo "$help_msg"
        ;;

    "assert")
        /usr/bin/log-create "$msg_id" --json \
            "{ \"VOLTAGE_REGULATOR\": \"${device_path}\", \"FAILURE_DATA\": \"$(get_failure_data "$gpio_name")\"}" \
            >"${stash_file}"
        ;;

    "deassert")
        msg_id="xyz.openbmc_project.State.Power.VoltageRegulatorFaultRecovered"
        if [ -s "${stash_file}" ]; then
            log-resolve -p "$(<"${stash_file}")" && rm "${stash_file}"
        fi
        /usr/bin/log-create "$msg_id" --json \
            "{ \"VOLTAGE_REGULATOR\": \"${device_path}\"}"
        ;;
esac

exit 0
