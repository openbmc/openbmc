SUBSYSTEM=="gpio", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea90", KERNELS=="1-1.2.1.4.2", SYMLINK+="gpio-cp2112-iob0", ENV{GPIO_NAME}="cp2112-IOB0", RUN+="/bin/sh -c 'gpioset /dev/gpio-cp2112-iob0 4=0; gpioset /dev/gpio-cp2112-iob0 5=0; gpioset /dev/gpio-cp2112-iob0 1=1'"

