#!/bin/bash

# shellcheck source=meta-facebook/recipes-fb/obmc_functions/files/fb-common-functions
source /usr/libexec/fb-common-functions

# Create /dev/mem
if [ ! -c /dev/mem ]; then
    /bin/mknod /dev/mem c 1 1
fi

# espi init
devmem 0x1e6ee000 32 0xff00ba55
devmem 0x1e6e2454 32 0xaa000000
devmem 0x1e6e2094 32 0x00000003

# Change SSC to -0.3% Down-spread
if [ -e "/dev/i2c-57" ] && i2cdetect -y 57 0x68 0x68 | grep -q -E "(68|UU)"; then
    i2cset -y 57 0x68 0x3c 0x34
fi

# Disable SSC to prevent xGMI Gen1 link drop
if i2cdetect -y 57 0x58 0x58 | grep -q -E "(58|UU)"; then
    i2ctransfer -f -y 57 w4@0x58 0x03 0xD3 0x00 0x0C
fi
