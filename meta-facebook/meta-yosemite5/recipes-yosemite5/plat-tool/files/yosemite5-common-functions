#!/bin/bash

FRU_SVC="xyz.openbmc_project.FruDevice"
FRU_ROOT="/xyz/openbmc_project/FruDevice"

set_gpio()
{
    local NET_NAME=$1
    local OUT_VAL=$2
    mapfile -t -d " " GPIO_INFO < <(gpiofind "$NET_NAME")
    if [ "${#GPIO_INFO[@]}" -ne 2 ]; then
        echo "set_gpio: can not find gpio, $NET_NAME"
        return 1
    fi

    echo -n "set_gpio: set $NET_NAME = $OUT_VAL"
    if ! gpioset "${GPIO_INFO[0]}" "${GPIO_INFO[1]%$'\n'}"="$OUT_VAL"; then
        echo " failed"
        return 1
    fi

    echo " success"
    return 0
}

get_gpio()
{
    local NET_NAME=$1
    local ret=2
    mapfile -t -d " " GPIO_INFO < <(gpiofind "$NET_NAME")
    if [ "${#GPIO_INFO[@]}" -ne 2 ]; then
        echo "get_gpio: can not find gpio, $NET_NAME"
        return 2
    fi

    echo -n "get_gpio: get $NET_NAME"
    if ! ret=$(gpioget "${GPIO_INFO[0]}" "${GPIO_INFO[1]%$'\n'}"); then
        echo " failed"
        return 2
    fi

    echo " success"
    return "${ret}"
}

find_fru_name()
{
    local KEYWORD="$1"
    local FRU_PATH

    if [ -z "$KEYWORD" ]; then
        echo "find_fru_name: no keyword provided" >&2
        return 1
    fi

    FRU_PATH=$(busctl tree "$FRU_SVC" --list --timeout=10s 2>/dev/null |
        grep -i "$KEYWORD" | head -n 1)

    if [ -z "$FRU_PATH" ]; then
        echo "find_fru_name: no FRU found for $KEYWORD" >&2
        return 1
    fi

    basename "$FRU_PATH"
}

get_product_version()
{
    local FRU_NAME="$1"
    local OUTPUT
    local VERSION
    local OBJ_PATH="$FRU_ROOT/$FRU_NAME"

    if [ -z "$FRU_NAME" ]; then
        echo "get_product_version: no name provided" >&2
        return 1
    fi

    if ! OUTPUT=$(busctl get-property --timeout=10s \
        "$FRU_SVC" "$OBJ_PATH" "$FRU_SVC" PRODUCT_VERSION 2>/dev/null); then
        echo "Unknown"
        return 1
    fi

    VERSION=$(echo "$OUTPUT" | cut -d'"' -f2)

    if [ -z "$VERSION" ] || [ "$VERSION" = "$OUTPUT" ]; then
        echo "get_product_version: parse error for $FRU_NAME" >&2
        echo "Unknown"
        return 1
    fi

    echo "$VERSION"
}
