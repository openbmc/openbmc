#!/bin/bash

# shellcheck source=meta-facebook/recipes-fb/obmc_functions/files/fb-common-functions
source /usr/libexec/fb-common-functions

# Power Good Status
power_status() {
    if [ "$(get_gpio "PWRGD_CPU_PWROK_1")" = "1" ]; then
        echo "on"
    else
        echo "off"
    fi
}

gpio_pulse() {
    local gpio=$1 assert=$2 duration=$3
    local deassert=$(( 1 - assert ))
    trap 'trap - INT TERM; echo "gpio_pulse($gpio): interrupted, restoring to $deassert" | systemd-cat -t power-cmd -p warning; set_gpio "$gpio" "$deassert"; exit 1' INT TERM
    set_gpio "$gpio" "$assert"
    sleep "$duration"
    set_gpio "$gpio" "$deassert"
    sleep 1
    trap - INT TERM
}

# Force DC off
force_power_off() {
    if [ "$(power_status)" == "on" ]; then
        gpio_pulse SYS_BMC_PWRBTN_N 0 5

        for _ in {1..10}; do
            sleep 1
            if [ "$(power_status)" == "off" ]; then
                return 0
            fi
        done
        return 1
    fi
    return 0
}

# Graceful DC off
graceful_power_off() {
    if [ "$(power_status)" == "on" ]; then
        gpio_pulse SYS_BMC_PWRBTN_N 0 1

        for _ in {1..180}; do
            sleep 1
            if [ "$(power_status)" == "off" ]; then
                return 0
            fi
        done
        return 1
    fi
    return 0
}

# DC on
power_on() {
    if [ "$(power_status)" == "off" ]; then
        gpio_pulse SYS_BMC_PWRBTN_N 0 1

        for _ in {1..10}; do
            sleep 1
            if [ "$(power_status)" == "on" ]; then
                return 0
            fi
        done
        return 1
    fi
    return 0
}

# Host reset
power_reset() {
    gpio_pulse SGPIO_RSTBTN_OUT 1 1
    return 0
}

is_service_busy() {
    local output active sub
    output=$(systemctl show -p ActiveState,SubState --value "$1")
    { read -r active; read -r sub; } <<< "$output"
    [ "$active" != "inactive" ] && [ "$sub" != "exited" ]
}
