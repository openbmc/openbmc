#!/bin/bash

# shellcheck source=meta-facebook/recipes-fb/obmc_functions/files/fb-common-functions
source /usr/libexec/fb-common-functions

# Power Good Status
power_status() {
    if [ "$(get_gpio "host0-ready")" -eq 1 ] ; then
        echo "on"
    else
        echo "off"
    fi
}

add_sel()
{
    local MSG_ID=$1
    local DEVICE_PATH=$2
    local LOG_TYPE=$3
    local LOG_CONTENT=$4

    /usr/bin/log-create "$MSG_ID" --json \
    "{ \"${LOG_TYPE}\": \"${DEVICE_PATH}\", \"FAILURE_DATA\": \"${LOG_CONTENT}\"}"
}

declare -A ERROR_MAP=(
    ["11"]="S5_PVDD33 Power on Fail"
    ["12"]="S5_PVDD18 Power on Fail"
    ["13"]="Wait SLP_S3 Power on Fail"
    ["14"]="S0_PVDDIO Power on Fail"
    ["15"]="PVDDCR_SOC_P0 Power on Fail"
    ["16"]="PVDDCR_CPU0_P0 Power on Fail"
    ["17"]="PVDDCR_CPU1_P0 Power on Fail"

    ["21"]="P12V_E1S_0 Power Fault"
    ["22"]="ASIC0 Power Fault"
    ["23"]="ASIC1 Power Fault"
    ["24"]="ASIC2 Power Fault"
    ["25"]="ASIC3 Power Fault"
    ["26"]="SWB Power Fault"
    ["27"]="PWRGD_PVDD33_S5"
    ["28"]="PWRGD_PVDD18_S5_P0"
    ["29"]="PVDDIO_MEM_S3_P0 Power Fault"
    ["2A"]="PVDDIO_P0 Power Fault"
    ["2B"]="PVDDCR_SOC_P0 Power Fault"
    ["2C"]="PVDDCR_CPU0_P0 Power Fault"
    ["2D"]="PVDDCR_CPU1_P0 Power Fault"

    ["30"]="System Leak"
    ["40"]="System power disable by RMC"
    ["50"]="STBY Fault"
    ["60"]="SLP_S5 Fault"
    ["70"]="No RMC power enable"

    ["80"]="ASIC0 Power on Fail"
    ["81"]="ASIC1 Power on Fail"
    ["82"]="ASIC2 Power on Fail"
    ["83"]="ASIC3 Power on Fail"

    ["90"]="SWB Fault"

    ["A1"]="DIMM CH A-D Power Fault"
    ["A2"]="DIMM CH E-H Power Fault"
    ["A3"]="DIMM CH I-L Power Fault"
    ["A4"]="DIMM CH M-P Power Fault"

    ["B0"]="CPU THERMTRIP fault"
    ["B1"]="RB#0 THERMTRIP fault"
    ["B2"]="RB#1 THERMTRIP fault"
    ["B3"]="RB#2 THERMTRIP fault"
    ["B4"]="RB#3 THERMTRIP fault"
)

declare -A GPIO_MODULE_PWR_EN=(
    [0]="FM_MODULE_PWR_EN_N_1B"
    [1]="FM_MODULE_PWR_EN_N_3B"
    [2]="FM_MODULE_PWR_EN_N_2B"
    [3]="FM_MODULE_PWR_EN_N_4B"
)

# Force DC off
force_power_off() {
    if [ "$(power_status)" == "on" ]; then
        trap 'trap - INT TERM; echo "force_power_off: interrupted, restoring power-host-control to 1" | systemd-cat -t power-cmd -p warning; set_gpio power-host-control 1; exit 1' INT TERM
        set_gpio power-host-control 0
        sleep 5
        set_gpio power-host-control 1
        trap - INT TERM
        sleep 1
    fi


    for i in $(seq 1 10)
    do
        sleep 1
        if [ "$(power_status)" == "off" ]; then
            return 0
        fi

        if [ "$i" -eq 10 ]; then
            return 1
        fi
    done

}

# Graceful DC off
graceful_power_off() {
    if [ "$(power_status)" == "on" ]; then
        trap 'trap - INT TERM; echo "graceful_power_off: interrupted, restoring power-host-control to 1" | systemd-cat -t power-cmd -p warning; set_gpio power-host-control 1; exit 1' INT TERM
        set_gpio power-host-control 0
        sleep 5
        set_gpio power-host-control 1
        trap - INT TERM
        sleep 1

        # wait host power off
        for i in $(seq 1 20)
        do
            sleep 1
            if [ "$(power_status)" == "off" ]; then
               break
            fi
        done
    fi
}

# DC on
power_on() {
    if [ "$(power_status)" == "off" ]; then
        set_gpio power-host-control 0
        sleep 1
        set_gpio power-host-control 1
        sleep 1

        for i in $(seq 1 10)
        do
            sleep 1
            if [ "$(power_status)" == "on" ]; then
               return 0
            fi

            if [ "$i" -eq 10 ]; then
                raw=$(i2cget -fy 21 0x33 0x20)
                error_code=${raw:2}
                decode=${ERROR_MAP[$error_code]:-"Unknown Error Code ($error_code)"}
                MSG_ID="xyz.openbmc_project.State.Power.PowerRailFault"
                DEVICE_PATH="/xyz/openbmc_project/inventory/system/board/Santabarbara_MB/power_on_sequence_fail"
                LOG_TYPE="POWER_RAIL"
                LOG_CONTENT="POWER_ON_SEQUENCE_FAIL - [$decode]"
                add_sel $MSG_ID $DEVICE_PATH $LOG_TYPE "$LOG_CONTENT"
               return 1
            fi
        done
    fi
    return 0
}

# Host reset
power_reset() {
    set_gpio CPU0_SYS_RESET_N 0
    sleep 1
    set_gpio CPU0_SYS_RESET_N 1
    sleep 1
    return 0
}

is_service_busy() {
    local output active sub
    output=$(systemctl show -p ActiveState,SubState --value "$1")
    { read -r active; read -r sub; } <<< "$output"
    [ "$active" != "inactive" ] && [ "$sub" != "exited" ]
}

module_power_control() {
    local SLOT_NUMBER=$1
    local ACTION=$2
    local NET_NAME="${GPIO_MODULE_PWR_EN[$SLOT_NUMBER]}"

    if [ "$ACTION" == "on" ]; then
        set_gpio "$NET_NAME" 0
    else
        set_gpio "$NET_NAME" 1
    fi

    return 0
}
