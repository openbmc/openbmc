[Unit]
Description=Ventura2 Fan Status Monitor
Wants=xyz.openbmc_project.fansensor.service
After=xyz.openbmc_project.fansensor.service

[Service]
ExecStart=/usr/libexec/plat-svc/ventura2-fan-status-monitor
SyslogIdentifier=Ventura2 Fan Status Monitor
Type=simple
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
