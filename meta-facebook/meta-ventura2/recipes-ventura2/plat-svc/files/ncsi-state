#!/bin/bash

INTERFACE=$(basename /sys/bus/platform/devices/1e690000.ethernet/net/eth*)
INDEX=$(cat /sys/bus/platform/devices/1e690000.ethernet/net/eth*/ifindex)
MAX_RETRIES=5
RETRY_COUNT=0
WAIT_TIME=15

echo "Target NCSI Interface: $INTERFACE (ifindex: $INDEX)"

while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
    state=$(timeout 2 ncsi-cmd -i "$INDEX" discover 2> /dev/null)
    ret=$?

    if [ $ret -eq 0 ] && echo "$state" | grep -q Found; then
        echo "NCSI Found E810"
        exit 0
    fi

    ip link set "$INTERFACE" down
    sleep 2
    ip link set "$INTERFACE" up

    echo "Wait $WAIT_TIME seconds for NCSI state"
    sleep $WAIT_TIME

    RETRY_COUNT=$((RETRY_COUNT + 1))
done

exit 1
